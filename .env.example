# Project Configuration
DATABASE_URL=postgresql://your_db_username:your_db_password@localhost:5432/event_tracker_db
DB_PASSWORD=your_db_password
VITE_APP_ID=event-tracker-app
VITE_API_URL=http://localhost:8080
VITE_OAUTH_PORTAL_URL=http://localhost:5173
OAUTH_SERVER_URL=http://localhost:8080
JWT_SECRET=your_jwt_secret_here
NODE_ENV=development
PORT=5173
SERVER_PORT=3000

# OAuth Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# Mail Configuration
MAIL_USERNAME=your_mail_username_here
MAIL_PASSWORD=your_mail_password_here

# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_MODEL=gemini-2.5-flash

# Analytics Configuration (optional)
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
