# Project Configuration
DATABASE_URL=postgresql://your_db_username:your_db_password@localhost:5432/event_tracker_db
VITE_APP_ID=event-tracker-app
VITE_API_URL=http://localhost:8080
VITE_OAUTH_PORTAL_URL=http://localhost:5173
OAUTH_SERVER_URL=http://localhost:8080
JWT_SECRET=put_your_very_long_secure_randomly_generated_string_here
CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:5173,http://localhost:3000,https://*.vercel.app
NODE_ENV=development
PORT=5173
SERVER_PORT=3000

# Production frontend on Vercel must set VITE_API_URL to the deployed Spring Boot
# origin, without /api. Example:
# VITE_API_URL=https://your-backend.onrender.com

# Analytics Configuration (optional)
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
