  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const token = pm.collectionVariables.get('token');",
          "const tokenCapturedAt = pm.collectionVariables.get('tokenCapturedAt');",
          "const testEmail = pm.collectionVariables.get('testEmail');",
          "const testPassword = pm.collectionVariables.get('testPassword');",
          "const baseUrl = pm.collectionVariables.get('baseUrl') || 'http://localhost:8080';",
          "",
          "const now = Date.now();",
          "const oneHour = 3600000;",
          "",
          "const path = pm.request.url.getPath();",
          "const isPublicEndpoint = path.includes('/auth/login') || path.includes('/auth/register');",
          "",
          "if (!isPublicEndpoint && (!token || !tokenCapturedAt || (now - tokenCapturedAt > oneHour))) {",
          "    pm.sendRequest({",
          "        url: baseUrl + '/api/auth/login',",
          "        method: 'POST',",
          "        header: {",
          "            'Content-Type': 'application/json'",
          "        },",
          "        body: {",
          "            mode: 'raw',",
          "            raw: JSON.stringify({ email: testEmail, password: testPassword })",
          "        }",
          "    }, function (err, res) {",
          "        if (err || res.code !== 200) {",
          "            console.error('Authentication failed: ', err || res.text());",
          "        } else {",
          "            const data = res.json();",
          "            pm.collectionVariables.set('token', data.token);",
          "            pm.collectionVariables.set('tokenCapturedAt', Date.now());",
          "            console.log('Token retrieved successfully for: ' + testEmail);",
          "        }",
          "    });",
          "}"
        ]
      }
    }
  ],
